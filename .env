APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
VECTORSTORE_DIR=./data/vectorstores
BM25_DIR=./data/bm25

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_REQUEST_RETRIES=2

MAX_UPLOAD_MB=50
MAX_FILES_PER_UPLOAD=5
MAX_DOCUMENTS_PER_USER=5
MAX_PAGES_PER_USER=800
MAX_PAGES_PER_DOCUMENT=800
CHUNK_SIZE_TOKENS=650
CHUNK_OVERLAP_TOKENS=130
RETRIEVAL_DENSE_TOP_K=24
RETRIEVAL_SPARSE_TOP_K=24
RETRIEVAL_FINAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.012
RETRIEVAL_MIN_QUERY_OVERLAP=2
RAG_CONTEXT_MAX_CHARS=24000
RRF_K=60

PUBLIC_REGISTRATION_ENABLED=true
